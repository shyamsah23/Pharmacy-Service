<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.I_care.Pharmacy_Service.mapper.SaleMapper">
    <resultMap id="SaleResultMap" type="com.I_care.Pharmacy_Service.entity.Sale">
        <id property="id" column="id"/>
        <result property="prescriptionId" column="prescription_id"/>
        <result property="saleDate" column="sale_date"/>
        <result property="totalAmount" column="total_amount"/>
    </resultMap>

    <insert id="addSale" parameterType="com.I_care.Pharmacy_Service.entity.Sale" useGeneratedKeys="true">
        Insert into sale (prescription_id,sale_date,total_amount)
        values (#{prescriptionId},#{saleDate},#{totalAmount})
    </insert>

    <select id="existsByPrescriptionId" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM sale
        WHERE prescription_id = #{prescriptionId};
    </select>

    <select id="findByPrescriptionId" resultMap="SaleResultMap">
        select * from sale where prescription_id = #{prescriptionId}
    </select>

    <update id="updateSale" parameterType="com.I_care.Pharmacy_Service.entity.Sale">
        UPDATE sale SET sale_date = #{saleDate}, total_amount = #{totalAmount} WHERE prescription_id =
        #{prescriptionId};
    </update>

    <select id="getSaleById" resultMap="SaleResultMap">
        Select * from sale where id=#{id};
    </select>

    <select id="getSaleByPrescriptionId" resultMap="SaleResultMap">
        Select * from sale where prescription_id=#{prescriptionId};
    </select>
</mapper>
